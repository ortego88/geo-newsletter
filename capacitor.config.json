{
  "appId": "com.trianio.app",
  "appName": "Trianio",
  "webDir": "dist",
  "server": {
    "url": "https://geo-newsletter-production.up.railway.app/app",
    "cleartext": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f172a",
      "showSpinner": true,
      "spinnerColor": "#E8B84B"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f172a"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
