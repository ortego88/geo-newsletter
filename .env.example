# .env.example — Variables de entorno para geo-newsletter
# Copia este archivo como .env para desarrollo local

# OpenAI (requerido para producción en Railway)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama (solo para desarrollo local, si no hay OPENAI_API_KEY)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Dashboard
PORT=8080

# Telegram (opcional, para alertas)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_ASSETS=  # Comma-separated list of assets to alert on (e.g. WTI,BTC,GOLD). Empty = all assets.

# Web app
SECRET_KEY=your-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
APP_DB_PATH=data/app.db
ADMIN_PASSWORD=change-me-in-production

# Cookie consent (Cookiebot). Leave empty in development (no banner shown).
COOKIEBOT_ID=

# WhatsApp (Twilio) — opcional, para alertas vía WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=

# Email (SMTP) — para el resumen semanal Premium/Pro
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=GEO-NEWSLETTER
SMTP_FROM_EMAIL=
